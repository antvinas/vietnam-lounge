rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function hasRole(role) {
      return isSignedIn() && role in request.auth.token.roles;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || hasRole('admin');
      allow create: if isOwner(uid);
      allow update, delete: if isOwner(uid) || hasRole('admin');
    }

    match /spots/{spotId} {
      allow read: if true;
      allow create: if hasRole('editor') || hasRole('admin');
      allow update, delete: if hasRole('editor') || hasRole('admin');
    }

    match /spots/{spotId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if (request.resource.data.authorUid == request.auth.uid)
                            || hasRole('moderator') || hasRole('admin');
    }

    match /reports/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if hasRole('moderator') || hasRole('admin');
    }

    match /admin/{doc=**} {
      allow read, write: if hasRole('admin');
    }
  }
}