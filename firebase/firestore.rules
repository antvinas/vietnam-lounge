rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to the spots collection for everyone
    match /spots/{spotId} {
      allow read: if true;
      allow write: if false; // Keep write access restricted
    }

    // Default rules for other collections (if any)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
