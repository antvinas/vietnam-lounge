# ===== Vite front-end envs (exposed to browser) =====
# 참고: Vite는 VITE_ 접두사만 import.meta.env.*로 노출함
# https://vite.dev/guide/env-and-mode

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: Functions region (기본 us-central1)
# VITE_FUNCTIONS_REGION=asia-southeast1

# Emulators toggle + ports
VITE_USE_EMULATORS=false
VITE_EMULATOR_HOST=localhost
VITE_EMU_AUTH_PORT=9099
VITE_EMU_FS_PORT=8080
VITE_EMU_STORAGE_PORT=9199
VITE_EMU_FN_PORT=5001

# 3rd-party
VITE_GOOGLE_MAPS_API_KEY=
